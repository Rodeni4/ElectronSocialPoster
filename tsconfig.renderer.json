{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "outDir": "dist/renderer",
    "rootDir": "src/renderer",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": [
    "src/renderer/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}